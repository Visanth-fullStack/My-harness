{
  "statusLine": {
    "type": "command",
    "command": "scripts/mnemos-statusline.sh",
    "padding": 0
  },
  "permissions": {
    "allow": [
      "Bash(npm test *)",
      "Bash(npm run lint *)",
      "Bash(npm run typecheck *)",
      "Bash(npx tsc *)",
      "Bash(npx jest *)",
      "Bash(npx vitest *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(eslint *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(wc *)",
      "Bash(icpg *)",
      "Bash(python -m icpg *)",
      "Bash(mnemos *)",
      "Bash(python -m mnemos *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Write(.env)",
      "Write(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_SCRIPT=; [ -x \".claude/scripts/mnemos-pre-compact.sh\" ] && HOOK_SCRIPT=\".claude/scripts/mnemos-pre-compact.sh\"; [ -z \"$HOOK_SCRIPT\" ] && [ -x \"$HOME/.claude/templates/mnemos-pre-compact.sh\" ] && HOOK_SCRIPT=\"$HOME/.claude/templates/mnemos-pre-compact.sh\"; [ -n \"$HOOK_SCRIPT\" ] && \"$HOOK_SCRIPT\" || true",
            "timeout": 8,
            "statusMessage": "Writing emergency checkpoint + compaction priorities..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_SCRIPT=; [ -x \".claude/scripts/mnemos-post-compact-inject.sh\" ] && HOOK_SCRIPT=\".claude/scripts/mnemos-post-compact-inject.sh\"; [ -z \"$HOOK_SCRIPT\" ] && [ -x \"$HOME/.claude/templates/mnemos-post-compact-inject.sh\" ] && HOOK_SCRIPT=\"$HOME/.claude/templates/mnemos-post-compact-inject.sh\"; [ -n \"$HOOK_SCRIPT\" ] && \"$HOOK_SCRIPT\" || true",
            "timeout": 2,
            "statusMessage": "Checking for post-compaction restore..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_SCRIPT=; [ -x \".claude/scripts/mnemos-pre-edit.sh\" ] && HOOK_SCRIPT=\".claude/scripts/mnemos-pre-edit.sh\"; [ -z \"$HOOK_SCRIPT\" ] && [ -x \"$HOME/.claude/templates/mnemos-pre-edit.sh\" ] && HOOK_SCRIPT=\"$HOME/.claude/templates/mnemos-pre-edit.sh\"; [ -n \"$HOOK_SCRIPT\" ] && \"$HOOK_SCRIPT\" || true",
            "timeout": 5,
            "statusMessage": "Checking fatigue + intent context..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_SCRIPT=; [ -x \".claude/scripts/mnemos-post-tool.sh\" ] && HOOK_SCRIPT=\".claude/scripts/mnemos-post-tool.sh\"; [ -z \"$HOOK_SCRIPT\" ] && [ -x \"$HOME/.claude/templates/mnemos-post-tool.sh\" ] && HOOK_SCRIPT=\"$HOME/.claude/templates/mnemos-post-tool.sh\"; [ -n \"$HOOK_SCRIPT\" ] && \"$HOOK_SCRIPT\" || true",
            "timeout": 1,
            "statusMessage": "Logging tool outcome..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_SCRIPT=; [ -x \".claude/scripts/tdd-loop-check.sh\" ] && HOOK_SCRIPT=\".claude/scripts/tdd-loop-check.sh\"; [ -z \"$HOOK_SCRIPT\" ] && [ -x \"$HOME/.claude/templates/tdd-loop-check.sh\" ] && HOOK_SCRIPT=\"$HOME/.claude/templates/tdd-loop-check.sh\"; [ -n \"$HOOK_SCRIPT\" ] && \"$HOOK_SCRIPT\" || true",
            "timeout": 60,
            "statusMessage": "Running tests..."
          },
          {
            "type": "command",
            "command": "HOOK_SCRIPT=; [ -x \".claude/scripts/icpg-stop-record.sh\" ] && HOOK_SCRIPT=\".claude/scripts/icpg-stop-record.sh\"; [ -z \"$HOOK_SCRIPT\" ] && [ -x \"$HOME/.claude/templates/icpg-stop-record.sh\" ] && HOOK_SCRIPT=\"$HOME/.claude/templates/icpg-stop-record.sh\"; [ -n \"$HOOK_SCRIPT\" ] && \"$HOOK_SCRIPT\" || true",
            "timeout": 5,
            "statusMessage": "Recording symbols to intent graph..."
          },
          {
            "type": "command",
            "command": "HOOK_SCRIPT=; [ -x \".claude/scripts/mnemos-stop-checkpoint.sh\" ] && HOOK_SCRIPT=\".claude/scripts/mnemos-stop-checkpoint.sh\"; [ -z \"$HOOK_SCRIPT\" ] && [ -x \"$HOME/.claude/templates/mnemos-stop-checkpoint.sh\" ] && HOOK_SCRIPT=\"$HOME/.claude/templates/mnemos-stop-checkpoint.sh\"; [ -n \"$HOOK_SCRIPT\" ] && \"$HOOK_SCRIPT\" || true",
            "timeout": 5,
            "statusMessage": "Writing session checkpoint..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_SCRIPT=; [ -x \".claude/scripts/mnemos-session-start.sh\" ] && HOOK_SCRIPT=\".claude/scripts/mnemos-session-start.sh\"; [ -z \"$HOOK_SCRIPT\" ] && [ -x \"$HOME/.claude/templates/mnemos-session-start.sh\" ] && HOOK_SCRIPT=\"$HOME/.claude/templates/mnemos-session-start.sh\"; [ -n \"$HOOK_SCRIPT\" ] && \"$HOOK_SCRIPT\" || true",
            "timeout": 5,
            "statusMessage": "Loading session checkpoint + project context..."
          }
        ]
      }
    ]
  }
}
