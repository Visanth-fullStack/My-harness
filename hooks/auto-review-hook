#!/bin/bash
# Stop hook — triggers autonomous multi-model review after significant changes.
# Conditions: file threshold, security paths, PR branches, review starvation.
# No set -euo pipefail: hook scripts must be defensive.

INPUT=$(cat 2>/dev/null || true)
CWD=$(echo "$INPUT" | jq -r '.cwd // empty' 2>/dev/null || echo ".")

cd "$CWD" 2>/dev/null || exit 0

# Guard: only fire every 10+ turns to avoid review spam
TURN_COUNT=$(echo "$INPUT" | jq -r '.turn_count // 0' 2>/dev/null || echo "0")

REVIEW_STATE="$HOME/.claude/auto-review-state.json"
LAST_REVIEW_TURN=$(cat "$REVIEW_STATE" 2>/dev/null | jq -r '.last_turn // 0' 2>/dev/null || echo "0")
TURNS_SINCE=$((TURN_COUNT - LAST_REVIEW_TURN))

# ── Trigger conditions ───────────────────────────────────────────────────
TRIGGER=0
REASON=""

# 1. File threshold: 5+ files changed or 200+ lines
git_diff=$(git diff --stat HEAD 2>/dev/null || true)
if [ -n "$git_diff" ]; then
  files_changed=$(echo "$git_diff" | wc -l)
  lines_changed=$(echo "$git_diff" | tail -1 | grep -oE '[0-9]+ insertion' | grep -oE '[0-9]+' || echo "0")
  if [ "$files_changed" -ge 5 ] 2>/dev/null; then
    TRIGGER=1
    REASON="$files_changed files changed"
  fi
fi

# 2. Security-sensitive paths modified
if git diff --name-only HEAD 2>/dev/null | grep -qiE '(auth|security|crypto|token|password|secret|encrypt)'; then
  TRIGGER=1
  REASON="security-sensitive paths"
fi

# 3. Review starvation: 15+ turns without review
if [ "$TURNS_SINCE" -ge 15 ] 2>/dev/null; then
  TRIGGER=1
  REASON="$TURNS_SINCE turns since last review"
fi

# 4. Don't review too frequently (min 8 turns between reviews)
if [ "$TURNS_SINCE" -lt 8 ] 2>/dev/null; then
  exit 0
fi

# ── Execute review ───────────────────────────────────────────────────────
if [ "$TRIGGER" -eq 1 ]; then
  echo "[auto-review] Triggered: $REASON (turn $TURN_COUNT)" >&2
  REVIEW_BIN="$HOME/bin/review"
  if [ -x "$REVIEW_BIN" ]; then
    # Run review in background to not block Claude
    nohup "$REVIEW_BIN" --deepseek --kimi "Review the recent changes in $CWD: $(git diff --stat HEAD 2>/dev/null | tail -5)" > "$HOME/.claude/last-review.txt" 2>&1 &
    # Update state
    echo "{\"last_turn\": $TURN_COUNT, \"ts\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\", \"reason\": \"$REASON\"}" > "$REVIEW_STATE"
  fi
fi

exit 0
